# ─── Serveur FTP (source des fichiers SOAP) ───────────────────────────
FTP_HOST=ftp.exemple.fr
FTP_PORT=21
FTP_USER=mon_utilisateur
FTP_PASSWORD=mon_mot_de_passe
# true = FTPS explicite (recommandé si le serveur le supporte), false = FTP simple
FTP_SECURE=false

# Dossier distant contenant les fichiers à traiter
FTP_DIR=/soap
# Dossier distant où archiver les fichiers traités (créé automatiquement si absent)
FTP_ARCHIVE_DIR=/soap/traites
# Filtre sur les noms de fichiers à traiter (regex JS, sans les slashes)
FTP_FILE_PATTERN=\.txt$

# Dossier des logs SOAP globaux (contient les validations de paiement). Vide pour désactiver.
FTP_GLOBAL_DIR=/global
# Taille max (octets) des fichiers /global téléchargés (les validations sont petites)
FTP_GLOBAL_MAX_SIZE=12000
# Scanner /global pour les validations de paiement (true/false)
SCAN_GLOBAL=true

# ─── Traitement ───────────────────────────────────────────────────────
# Action après extraction réussie : "archive" (déplace) | "delete" (supprime) | "keep" (laisse)
AFTER_PROCESS=archive

# ─── Planificateur ────────────────────────────────────────────────────
# Activer le scan automatique (true/false)
SCHEDULE_ENABLED=true
# Expression cron (par défaut : toutes les 15 minutes)
SCHEDULE_CRON=*/15 * * * *

# ─── Serveur web ──────────────────────────────────────────────────────
PORT=3010
# Chemin du fichier base SQLite
DB_PATH=./data/soap.db

# ─── Authentification ─────────────────────────────────────────────────
# Identifiant et mot de passe INITIAL (à changer ensuite dans l'interface)
AUTH_USER=admin
AUTH_PASSWORD=camping

# ─── Purge automatique (RGPD) ─────────────────────────────────────────
# Activer la purge (true/false)
PURGE_ENABLED=true
# Supprimer les données plus anciennes que N jours
PURGE_RETENTION_DAYS=7
# Quand lancer la purge (cron, par défaut tous les jours à 3h30)
PURGE_CRON=30 3 * * *
